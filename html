<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Magic 0 Ball</title>

  <!-- Doto Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Doto:wght,ROND@100..900,100&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#000;
      --ballHighlight: rgba(255,255,255,0.55);
      --ballShadow: rgba(0,0,0,0.28);
      --badge:#f2f2f6;
      --badgeRing: rgba(0,0,0,0.10);
      --badgeText:#111;
      --text:#ffffff;
    }

    html,body{
      height:100%;
      margin:0;
      background:var(--bg);
      overflow:hidden;
      font-family: system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
    }

    .stage{
      min-height:100%;
      display:grid;
      place-items:center;
      padding:28px 18px;
      box-sizing:border-box;
    }

    .center-slot{
      position:relative;
      width:min(360px,78vw);
      height:min(360px,78vw);
      display:grid;
      place-items:center;
    }

    .shake-wrap{
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      will-change: transform;
    }

    .zeroball{
      position:absolute;
      inset:0;
      border-radius:50%;
      border:0;
      cursor:pointer;
      outline:none;
      -webkit-tap-highlight-color: transparent;

      background:
        radial-gradient(140px 140px at 30% 25%, var(--ballHighlight), transparent 62%),
        radial-gradient(240px 240px at 65% 75%, rgba(0,0,0,0.06), transparent 70%),
        radial-gradient(closest-side, #ffffff, #f5f5f7);

      box-shadow:
        0 22px 50px var(--ballShadow),
        inset 0 -18px 30px rgba(0,0,0,0.10),
        inset 0 14px 24px rgba(255,255,255,0.55);

      display:grid;
      place-items:center;
      transition: opacity 520ms ease;
    }

    .zeroball.hidden{
      opacity:0;
      pointer-events:none;
    }

    .badge{
      width:44%;
      height:44%;
      border-radius:50%;
      background: radial-gradient(circle at 35% 30%, #ffffff, var(--badge));
      display:grid;
      place-items:center;
      position:relative;
      user-select:none;
      box-shadow:
        inset 0 -8px 14px rgba(0,0,0,0.10),
        inset 0 6px 10px rgba(255,255,255,0.85);
    }

    .badge::before{
      content:"";
      position:absolute;
      inset:10%;
      border-radius:50%;
      box-shadow: inset 0 0 0 2px var(--badgeRing);
      opacity:0.9;
    }

    .zero{
      font-weight:900;
      font-size:clamp(46px,7vw,74px);
      line-height:1;
      color:var(--badgeText);
      letter-spacing:-1px;
      transform: translateY(-1px);
    }

    .center-text{
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      text-align:center;
      color:var(--text);
      opacity:0;
      transform: translateY(-6px);
      transition: opacity 520ms ease, transform 520ms ease;
      pointer-events:none;
      padding:18px;
      box-sizing:border-box;
    }

    .center-text.show{
      opacity:1;
      transform: translateY(0);
    }

    .typed{
      max-width:min(980px,94vw);
      font-family:"Doto", sans-serif;
      font-optical-sizing:auto;
      font-weight:420;
      font-variation-settings:"ROND" 100;
      font-style: normal;
      font-size:clamp(18px,1.4vw + 14px,26px);
      line-height:1.4;
      white-space:pre-wrap;
      overflow-wrap:anywhere;
      letter-spacing:0.3px;
    }

/* Smooth sinusoidal-style bob */
@keyframes smoothBob {
  0%   { transform: translateY(0); }
  50%  { transform: translateY(-14px); }
  100% { transform: translateY(0); }
}

/* 0.5s per oscillation × 5 cycles = 2.5s total */
.shake-wrap.shaking {
  animation: smoothBob 0.5s ease-in-out 5;
}

    @media (prefers-reduced-motion: reduce){
      .shake-wrap.shaking{ animation:none; }
      .zeroball, .center-text{ transition:none; }
    }
  </style>
</head>
<body>
  <main class="stage">
    <div class="center-slot" aria-live="polite" aria-atomic="true">
      <div class="shake-wrap" id="shakeWrap">
        <button class="zeroball" id="ball" aria-label="Magic 0 Ball">
          <div class="badge" aria-hidden="true">
            <div class="zero">0</div>
          </div>
        </button>
      </div>

      <div class="center-text" id="centerText">
        <div class="typed" id="typed"></div>
      </div>
    </div>
  </main>

  <script>
    const answers = [
      "Total certainty here is, certainly, totally impossible.",
      "There is nothing to know, the world is always already a perfection.",
      "Ambiguity is forever, only faith survives the abyss.",
      "You know everything you could have known by this moment.",
      "It would serve you just as well to not want to know.",
      "You will find clarity exactly when your search for it ceases to be necessary.",
      "The answer will not totally end your uncertainty anyway."
    ];

    const n = answers.length;
    const ball = document.getElementById("ball");
    const shakeWrap = document.getElementById("shakeWrap");
    const centerText = document.getElementById("centerText");
    const typedEl = document.getElementById("typed");

    let busy = false;
    let cycleHistory = [];

    function pickIndexWithCycleReset(){
      if (cycleHistory.length >= n){
        cycleHistory = [];
        const idx = Math.floor(Math.random() * n);
        cycleHistory.push(idx);
        return idx;
      }
      const used = new Set(cycleHistory);
      const candidates = [];
      for (let i = 0; i < n; i++){
        if (!used.has(i)) candidates.push(i);
      }
      const idx = candidates[Math.floor(Math.random() * candidates.length)];
      cycleHistory.push(idx);
      return idx;
    }

    const sleep = (ms) => new Promise(r => setTimeout(r, ms));
    let abortTyping = false;

    async function typeText(text){
      abortTyping = false;
      typedEl.textContent = "";

      const baseDelay = 36;
      const jitter = 34;
      const punctuationPause = 220;

      for (const ch of text){
        if (abortTyping) return;

        typedEl.textContent += ch;

        let delay = baseDelay + Math.random() * jitter;
        if (/[.,;:!?]/.test(ch)) delay += punctuationPause;
        if (ch === " ") delay += 14;

        await sleep(delay);
      }
    }

    ball.addEventListener("click", async () => {
      if (busy) return;
      busy = true;
      abortTyping = true;

      centerText.classList.remove("show");
      typedEl.textContent = "";

      // bob for 2.5 seconds
      shakeWrap.classList.add("shaking");
      await sleep(2500);
      shakeWrap.classList.remove("shaking");

      // fade out ball
      ball.classList.add("hidden");
      await sleep(520);

      // type answer
      const answer = answers[pickIndexWithCycleReset()];
      centerText.classList.add("show");
      await sleep(260);
      await typeText(answer);

      // hold for 4 seconds
      await sleep(4000);

      // fade out text
      centerText.classList.remove("show");
      await sleep(520);

      typedEl.textContent = "";
      ball.classList.remove("hidden");
      await sleep(520);

      busy = false;
    });
  </script>
</body>
</html>
